        "jsCode": "// Captura el array completo de filas leídas de Google Sheets\nconst items = $input.all();\n\nlet totalProcesadas = items.length;\nlet aprobadas = 0;\nlet rechazadas = 0;\n\nfor (const elemento of items) {\n  // Extraemos el texto de la columna exacta 'Resultado Análisis'\n  // Usamos minúsculas para evitar problemas de coincidencia exacta\n  const analisis = (elemento.json['Resultado Análisis'] || '').toLowerCase();\n  \n  // Evaluamos según cómo inicia el estado en tu columna H\n  if (analisis.includes('aprobado')) {\n    aprobadas++;\n  } else if (analisis.includes('invalido') || analisis.includes('inválido') || analisis.includes('no se recibió')) {\n    rechazadas++;\n  }\n    \n}\n\n// Retornamos el conteo final unificado para el mensaje de Telegram\nreturn [{\n  json: {\n    total: totalProcesadas,\n    aprobadas: aprobadas,\n    rechazadas: rechazadas\n  }\n}];"
      },
